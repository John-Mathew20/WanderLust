<% layout("/layouts/boilerplate")%>
<body>
  <div class="row">
    <div class="col-8 offset-3 mt-2">
      <h3><b><%=listing.title%></b></h3>
    </div>
  </div>
  <div class="card col-6 offset-3 show-card listing-card">
    <img
      src="<%= listing.image %>"
      class="card-img-top show-img"
      alt="listing_image"
    />
    <div class="card-body">
      <p class="card-text">
        <%=listing.description%>
        <br />
        &#8377;<%=listing.price.toLocaleString("en-IN")%>
        <br />
        <%=listing.location%>
        <br />
        <%=listing.country%>
      </p>
    </div>

    <div class="btns">
      <a href="/listings/<%=listing._id%>/edit">
        <button class="btn btn-dark offset-3 edit-btn">Edit</button>
      </a>
      <form action="/listings/<%= listing._id %>?_method=Delete" method="post">
        <button class="btn btn-dark offset-5">Delete</button>
      </form>
    </div>
  </div>

  <div class="col-8 offset-3">
    <hr />
    <h4>Leave A Review</h4>
    <form
      action="/listings/<%= listing._id %>/reviews"
      method="post"
      class="mt-3 mb-3 needs-validation"
      novalidate
    >
      <div class="mt-3 mb-3">
        <label for="rating" class="form-label">Rating</label>
        <input
          type="range"
          name="review[rating]"
          min="1"
          max="5"
          id="rating"
          class="form-range"
        />
      </div>
      <div class="mt-3 mb-3">
        <label for="comment" class="form-label">Comment</label>
        <textarea
          name="review[comment]"
          id="comment"
          cols="30"
          rows="5"
          class="form-control"
          required
        ></textarea>
        <div class="valid-feedback">Looks Great!</div>
        <div class="invalid-feedback">Something is Off !?</div>
      </div>
      <button class="btn btn-outline-dark">Submit</button>
    </form>
    
    <h5><b>All Reviews</b></h5>
    <div class="row">
      <%for(let review of listing.reviews) { %>
        <div class="card col-5 ms-3 mb-3">
          <div class="card-body">
            <h5 class="card-title">Jane Doe</h5>
            <p class="card-text"><%= review.rating %> Stars
            </p>
            <p class="card-text">
              <%= review.comment %>
            </p>
          </div>
          <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=Delete" method="post">
            <button class="btn btn-dark">
              Delete
            </button></form>
          </div>
          <% } %>
        </div> 
      </div>

</body>
